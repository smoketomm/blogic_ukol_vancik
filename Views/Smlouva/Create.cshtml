@model (List<Blogic_ukol_vancik.Models.Klient> Klients, List<Blogic_ukol_vancik.Models.Spravce> Spravci)

@{
	ViewData["Title"] = "Vytvoreni smlouvy";
}

<head>
	<title>@ViewData["Title"] - vytvoř smlouvu</title>
</head>

<div class="container">
  <form asp-controller="Smlouva" asp-action="VytvoritSmlouvu" method="post">
    <div class="form-group">
        <label for="InstituceID">Instituce</label>
        <input required type="text" class="form-control" id="instituceID" name="novasmlouva.Instituce" aria-describedby="instituceHelp" placeholder="Zadejte instituci">
        <small id="instituceHelp" class="form-text text-muted">Instituce, která uzavírá smlouvu.</small>
    </div>
    <div class="form-group">
      <label for="klientID">Klient</label>
      <select class="form-control" id="klientID" name="novasmlouva.Klient">

        <option selected>Vyberte klienta...</option>
                @foreach(var klient in Model.Klients)
                    {
                        <option value="@klient.ID|@klient.Jmeno @klient.Prijmeni">@klient.Jmeno @klient.Prijmeni</option>
                    }
                </select>
    </div>
      <div class="form-group">
      <label for="spravciID">Spracvci</label>
            @foreach (var spravci in Model.Spravci)
            {
                if (spravci.ID == 8)
                {
                    continue;
                }
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="@spravci.ID" name="Spravci" value="@spravci.ID">
                    <label class="form-check-label" for="id=@spravci.ID">@spravci.Jmeno @spravci.Prijmeni #@spravci.ID.ToString("D4")</label>
                </div>
            }
          </div>
   <div class="form-group">
    <label for="datumPlatnostiID">Datum platnosti</label>
    <input required type="date" class="form-control" id="datumPlatnostiID" name="novasmlouva.DatumPlatnosti" aria-describedby="datumPlatnostiHelp">
    <small id="datumPlatnostiHelp" class="form-text text-muted">Zvolte datum platnosti</small>
  </div>
     <div class="form-group mb-3">
    <label for="datumUkonceniID">Datum Ukonceni</label>
    <input required type="date" class="form-control" id="datumUkonceniID" name="novasmlouva.DatumUkonceni" aria-describedby="datumUkonceniHelp">
    <small id="datumUkonceniHelp" class="form-text text-muted">Zvolte datum Ukonceni</small>
  </div>
    <button class="btn btn-primary">Vytvořit Smlouvu</button>
 </form>
</div>
