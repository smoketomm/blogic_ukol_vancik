
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Blogic_ukol_vancik</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Blogic_ukol_vancik.styles.css" asp-append-version="true" />
    <script src="https://kit.fontawesome.com/0661eb526e.js" crossorigin="anonymous"></script>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Blogic_ukol_vancik</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 d-flex justify-content-between">
                        <div class="d-flex">
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                            </li>
                        </div>
                        <div class="d-flex align-items-center">
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Spravce" asp-action="Index">Spravci</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Klient" asp-action="Index">Klienti</a>
                            </li>
                            <li class="nav-item d-flex">
                                @if (_uzivatelContext.aktualniUzivatel != null && User.Identity.IsAuthenticated)
                                {
                                    <span class="nav-link text-dark">Přihlášen jako: @_uzivatelContext.aktualniUzivatel.Jmeno @_uzivatelContext.aktualniUzivatel.Prijmeni - @(_uzivatelContext.aktualniUzivatel.JeSpravce ? "Správce" : "Klient") | </span>
                                    <form asp-controller="Home" asp-action="Odhlasit" method="post" class="d-inline">
                                        <button type="submit" class="btn btn-link nav-link text-dark">Odhlásit se</button>
                                    </form>
                                }
                                else if (_uzivatelContext.aktualniUzivatel == null)
                                {
                                    <span class="nav-link text-dark">Přihlášen jako: Host</span>
                                }
                            </li>
                        </div>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div>
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Blogic_ukol_vancik - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
